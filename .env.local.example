# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and paste your real key. NEVER commit .env.local.
# The key lives only on the server (in the API route), so it is never exposed
# to the browser.
# ---------------------------------------------------------------------------

# Anthropic (default provider used in app/api/chat/route.js)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- If you prefer OpenAI instead, set this and swap the provider in route.js ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
